generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id         String    @id @default(cuid())
  lineageId  String
  name       String
  gender     Gender
  generation Int       @default(1)
  birthDate  DateTime?
  deathDate  DateTime?
  photoUrl   String?
  phone      String?
  address    String?
  latLong    String?
  bio        String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  isDeceased Boolean   @default(false)
  asChild    Child[]
  lineage    Lineage   @relation(fields: [lineageId], references: [id])
  partner1At Family[]  @relation("Partner1")
  partner2At Family[]  @relation("Partner2")
}

model Family {
  id         String   @id @default(cuid())
  lineageId  String
  partner1Id String
  partner2Id String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  children   Child[]
  lineage    Lineage  @relation(fields: [lineageId], references: [id])
  partner1   Person   @relation("Partner1", fields: [partner1Id], references: [id])
  partner2   Person?  @relation("Partner2", fields: [partner2Id], references: [id])
}

model Child {
  id               String           @id @default(cuid())
  familyId         String
  childId          String
  relationshipType RelationshipType @default(BIOLOGICAL)
  child            Person           @relation(fields: [childId], references: [id], onDelete: Cascade)
  family           Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, childId])
}



model Lineage {
  id         String   @id @default(cuid())
  name       String
  accessCode String   @unique
  createdAt  DateTime @default(now())

  persons    Person[]
  families   Family[]
}



enum Gender {
  MALE
  FEMALE
}

enum RelationshipType {
  BIOLOGICAL
  ADOPTED
  STEPCHILD
}


